.cache/
.eslintcache
.stylelintcache
.turbo/
.parcel-cache/
tmp/
temp/
*.tmp
*.temp

# test and browser-runner artifacts
/test-results/
/playwright-report/
/blob-report/
/.vitest/

# local databases
*.db
*.db-journal
*.sqlite
*.sqlite3

