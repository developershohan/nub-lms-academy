# Copy this file to .env and fill in real values. Never commit .env itself - see .gitignore.

# ---------------------------------------------------------------------------
# Shared application configuration
# ---------------------------------------------------------------------------
APP_NAME="LMS Platform"
NODE_ENV="development"

# ---------------------------------------------------------------------------
# Next.js / Vercel
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Shared by Vercel (Next.js app) and Render (socket server) - values MUST match on both
# ---------------------------------------------------------------------------
# Point this at a local/Neon/Supabase Postgres instance, then run: npx prisma migrate dev
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Signs both the NextAuth session JWT and the short-lived socket auth token - the socket server
# verifies tokens using this same value (see src/lib/socket-token.ts).
AUTH_SECRET="replace-with-a-new-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-value-as-AUTH_SECRET"

# Shared secret guarding socket-server's POST /internal/emit bridge (server-to-server only,
# never sent to the browser).
SOCKET_INTERNAL_SECRET="replace-with-a-new-random-secret"

# ---------------------------------------------------------------------------
# OAuth - Vercel only
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

ADMIN_EMAIL="admin@example.com"

# ---------------------------------------------------------------------------
# Stripe - Vercel only
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From the Stripe Dashboard (or `stripe listen --print-secret` for local testing). Leave empty to
# disable webhook processing - checkout/refunds still work, auto-enrollment on payment does not.
STRIPE_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Email (Resend) - Vercel only
# ---------------------------------------------------------------------------
# From resend.com/api-keys. Leave empty to disable sending - verification/reset links are logged
# to the console instead (development only; nothing is logged in production, see docs/security.md).
RESEND_API_KEY=""
# Must be "onboarding@resend.dev" (Resend's shared sandbox sender, only delivers to the address
# you signed up with) until a custom domain is verified in Resend, e.g. "NUB Academy <noreply@yourdomain.com>".
EMAIL_FROM="NUB Academy <onboarding@resend.dev>"

# ---------------------------------------------------------------------------
# Socket client / Next.js server - Vercel
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_* is baked into the client bundle at build time - changing it requires a redeploy,
# not just an env var update. Both should point at wherever socket-server is actually hosted.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_SERVER_URL="http://localhost:3001"

# ---------------------------------------------------------------------------
# Standalone socket server - Render (or wherever it's deployed)
# ---------------------------------------------------------------------------
# Local dev only - hosts like Render/Railway inject PORT themselves and it takes priority.
SOCKET_PORT="3001"
# Comma-separated allow-list of origins allowed to connect (no trailing slash, no "*").
SOCKET_CORS_ORIGIN="http://localhost:3000"
