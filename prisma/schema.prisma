// Prisma schema for NUB Academy LMS
// Phase 1: auth, roles, permissions foundation.
// Phase 2: course catalog (courses, sections, lessons, categories).
// Quiz/payment/chat models are added in later phases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum RoleName {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum TeacherApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts       Account[]
  sessions       Session[]
  roles          UserRole[]
  teacherProfile TeacherProfile?
  bans           UserBan[]        @relation("BannedUser")
  bansIssued     UserBan[]        @relation("BannedBy")
  courses        Course[]
  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  reviews        CourseReview[]
  wishlist       Wishlist[]
  quizAttempts   QuizAttempt[]
  certificates   Certificate[]

  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id    String     @id @default(cuid())
  name  RoleName   @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model TeacherProfile {
  id        String                   @id @default(cuid())
  userId    String                   @unique
  status    TeacherApplicationStatus @default(PENDING)
  headline  String?
  bio       String?                  @db.Text
  appliedAt DateTime                 @default(now())
  reviewedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBan {
  id         String   @id @default(cuid())
  userId     String
  bannedById String?
  reason     String
  createdAt  DateTime @default(now())

  user     User  @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User? @relation("BannedBy", fields: [bannedById], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId])
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum CourseStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
}

model Course {
  id                     String       @id @default(cuid())
  title                  String
  slug                   String       @unique
  subtitle               String?
  description            String?      @db.Text
  thumbnailUrl           String?
  targetAudience         String?      @db.Text
  level                  CourseLevel  @default(ALL_LEVELS)
  language               String       @default("English")
  price                  Decimal      @default(0) @db.Decimal(10, 2)
  salePrice              Decimal?     @db.Decimal(10, 2)
  isSubscriptionIncluded Boolean      @default(false)
  status                 CourseStatus @default(DRAFT)
  rejectionReason        String?
  publishedAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  teacherId  String
  teacher    User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sections     CourseSection[]
  requirements CourseRequirement[]
  outcomes     CourseOutcome[]
  enrollments  Enrollment[]
  reviews      CourseReview[]
  wishlistedBy Wishlist[]
  quizzes      Quiz[]
  certificates Certificate[]

  @@index([status])
  @@index([teacherId])
  @@index([categoryId])
}

model CourseRequirement {
  id        String @id @default(cuid())
  courseId  String
  content   String
  sortOrder Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseOutcome {
  id        String @id @default(cuid())
  courseId  String
  content   String
  sortOrder Int    @default(0)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseSection {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  type        LessonType @default(TEXT)
  content     String?    @db.Text
  durationSec Int?
  sortOrder   Int        @default(0)
  isPreview   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  section    CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  videoAsset VideoAsset?
  progress   LessonProgress[]
  quiz       Quiz?

  @@index([sectionId])
}

model VideoAsset {
  id              String      @id @default(cuid())
  lessonId        String      @unique
  provider        String      @default("external")
  providerAssetId String?
  playbackUrl     String
  durationSec     Int?
  status          VideoStatus @default(READY)
  uploadedById    String
  createdAt       DateTime    @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  REFUNDED
  CANCELLED
  REVOKED
}

enum EnrollmentSource {
  FREE
  PURCHASE
  SUBSCRIPTION
  ADMIN_GRANT
  COUPON
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  source      EnrollmentSource @default(FREE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  watchedSeconds Int       @default(0)
  completed      Boolean   @default(false)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?  @db.Text
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

model Quiz {
  id           String   @id @default(cuid())
  courseId     String
  lessonId     String?  @unique
  title        String
  description  String?  @db.Text
  passingScore Int      @default(70)
  maxAttempts  Int?
  timeLimitSec Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  prompt    String       @db.Text
  type      QuestionType @default(SINGLE_CHOICE)
  points    Int          @default(1)
  sortOrder Int          @default(0)

  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers QuizAnswer[]

  @@index([quizId])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  content    String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String            @id @default(cuid())
  quizId      String
  userId      String
  status      QuizAttemptStatus @default(IN_PROGRESS)
  score       Int?
  passed      Boolean?
  startedAt   DateTime          @default(now())
  submittedAt DateTime?

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId, userId])
}

model QuizAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  selectedOptionIds String[]
  isCorrect         Boolean  @default(false)

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model Certificate {
  id                String    @id @default(cuid())
  certificateNumber String    @unique
  userId            String
  courseId          String
  // Snapshot fields so a certificate stays a stable historical record even if the
  // student renames themselves or the course/teacher details change later.
  studentName       String
  courseTitle       String
  teacherName       String
  completedAt       DateTime
  issuedAt          DateTime  @default(now())
  revoked           Boolean   @default(false)
  revokedAt         DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
